# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# News Sources
NEWSAPI_ORG_KEY=your_newsapi_key

# AI
# 두 역할로 provider 를 분리할 수 있다.
#   AI_PROVIDER_1 : 기사 수집 부수 작업 (영어 번역 등)
#   AI_PROVIDER_2 : 메인 브리핑(요약) 생성
# 둘 다 유효(키 설정됨)면 역할별로 분리 사용. 한쪽만 유효하면 그 한쪽이 모두 처리.
# 둘 다 비어있으면 레거시 AI_PROVIDER → 그도 없으면 anthropic 기본.
# 값: anthropic | gemini | openai
AI_PROVIDER_1=
AI_PROVIDER_2=
# (legacy, optional) — 새 변수 미설정 시 fallback
AI_PROVIDER=

ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=
OPENAI_API_KEY=
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Email
RESEND_API_KEY=re_xxx

# Cron Security
CRON_SECRET=your_random_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
