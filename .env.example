# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# News Sources
NEWSAPI_ORG_KEY=your_newsapi_key

# AI
# 두 단계로 워크로드를 분배한다.
#   AI_PROVIDER_1 (Stage 1):
#     - 기사 수집: 빠른 수집 + 1차 카테고리 분류 (배치)
#     - 브리핑 생성: 초안 생성
#     - 영어 번역
#   AI_PROVIDER_2 (Stage 2):
#     - 기사 수집: 1차로 결정 못한 기사 카테고리/키워드 분배
#     - 브리핑 생성: 초안 검수 및 보완
# 둘 다 유효(키 설정됨)하면 단계별 분리 사용. 한쪽만 유효하면 그 한쪽이 양쪽 처리.
# 둘 다 비어있으면 레거시 AI_PROVIDER → anthropic 기본.
# 값: anthropic | gemini | openai
AI_PROVIDER_1=
AI_PROVIDER_2=
# (legacy, optional) — 새 변수 미설정 시 fallback
AI_PROVIDER=

ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=
OPENAI_API_KEY=
# Optional — defaults to gpt-5-mini
OPENAI_MODEL=gpt-5-mini

# Email
RESEND_API_KEY=re_xxx

# Cron Security
CRON_SECRET=your_random_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
